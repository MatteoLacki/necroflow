#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if [ ! -f .venv/bin/black ] || [ ! -f .venv/bin/pytest ]; then
    echo "[pre-commit] .venv is missing black or pytest — run 'make venv' first" >&2
    exit 1
fi

mapfile -t python_files < <(git ls-files '*.py')
if [ "${#python_files[@]}" -gt 0 ]; then
    echo "[pre-commit] formatting Python files with black..."
    .venv/bin/black "${python_files[@]}"
    git add "${python_files[@]}"
fi

echo "[pre-commit] running pytest..."
.venv/bin/pytest -q
